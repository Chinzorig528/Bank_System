<Window
    x:Class="TellerApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:TellerApp.ViewModels"
    mc:Ignorable="d">

    <Grid
    x:Name="RootGrid"
    Background="#1E1E1E">

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="20">

            <TextBlock
                Text="TELLER SYSTEM"
                FontSize="36"
                FontWeight="Bold"
                Foreground="White"
                HorizontalAlignment="Center"/>

            <Border
                Width="400"
                Height="200"
                CornerRadius="20"
                Background="#2D2D30"
                Padding="20">

                <StackPanel Spacing="10">

                    <TextBlock
                        Text="Current Ticket"
                        FontSize="20"
                        Foreground="Gray"/>

                    <TextBlock
                        Text="{Binding CurrentTicket.TicketNumber}"
                        FontSize="48"
                        FontWeight="Bold"
                        Foreground="Lime"/>

                    <TextBlock
                        Text="{Binding CurrentTicket.ServiceType}"
                        FontSize="24"
                        Foreground="White"/>
                </StackPanel>
            </Border>

            <StackPanel
                Orientation="Horizontal"
                Spacing="20"
                HorizontalAlignment="Center">

                <Button
                    Content="Call Next"
                    Width="180"
                    Height="60"
                    Command="{Binding CallNextCommand}"/>

                <Button
                    Content="Complete"
                    Width="180"
                    Height="60"
                    Command="{Binding CompleteCommand}"/>
            </StackPanel>

        </StackPanel>

    </Grid>
</Window>