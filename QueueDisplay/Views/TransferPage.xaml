<Page
    x:Class="QueueDisplay.Views.TransferPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1E1E1E">

        <StackPanel
            Width="400"
            Spacing="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock
                Text="TRANSFER"
                FontSize="36"
                FontWeight="Bold"
                Foreground="White"/>

            <TextBox
                x:Name="FromAccountBox"
                Header="From Account"/>

            <TextBox
                x:Name="ToAccountBox"
                Header="To Account"/>

            <TextBox
                x:Name="AmountBox"
                Header="Amount"/>

            <Button
                Content="Transfer"
                Height="50"
                Click="Transfer_Click"/>

            <TextBlock
                x:Name="ResultText"
                Foreground="Lime"/>

        </StackPanel>

    </Grid>
</Page>