<Page
    x:Class="QueueDisplay.Views.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1E1E1E">

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="20">

            <TextBlock
                Text="QUEUE SYSTEM"
                FontSize="36"
                FontWeight="Bold"
                Foreground="White"/>

            <Border
                Width="400"
                Height="200"
                CornerRadius="20"
                Background="#2D2D30"
                Padding="20">

                <StackPanel>

                    <TextBlock
                        Text="Current Ticket"
                        FontSize="20"
                        Foreground="Gray"/>

                    <TextBlock
                        x:Name="TicketText"
                        Text="A001"
                        FontSize="60"
                        FontWeight="Bold"
                        Foreground="Lime"/>

                </StackPanel>

            </Border>

            <StackPanel
                Orientation="Horizontal"
                Spacing="20">

                <Button
                    Content="Call Next"
                    Width="180"
                    Height="60"
                    Click="CallNext_Click"/>

                <Button
                    Content="Complete"
                    Width="180"
                    Height="60"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Page>